# XRPL Network Configuration
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Optional: Custom network endpoints
# NEXT_PUBLIC_TESTNET_WSS=wss://s.altnet.rippletest.net:51233
# NEXT_PUBLIC_TESTNET_FAUCET=https://faucet.altnet.rippletest.net/accounts

# Edel-ID EUDI Wallet Verifier (server-side only)
# Get credentials from your Edel-ID contact
EDEL_ID_API_KEY=your_api_key_here
EDEL_ID_API_SECRET=your_api_secret_here
EDEL_ID_VERIFIER_URL=https://verifier.edel-id.ch
MOCK_KYC=true
